RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Prevent directory listing
Options -Indexes

# CORS headers
<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Origin "*"
    Header always set Access-Control-Allow-Methods "GET, POST, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Api-Key"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
</IfModule>

# Block direct access to logs and JSON files
<FilesMatch "\.(log)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to config PHP files and service account
<FilesMatch "(firebase-config|firebase-admin|service-account|site-config)">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to sensitive files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Prevent PHP execution in uploads directory
<IfModule mod_rewrite.c>
    RewriteRule ^uploads/.*\.php$ - [F,L]
</IfModule>

# PHP settings for Hostinger shared hosting (LiteSpeed compatible)
php_value max_execution_time 120
php_value memory_limit 256M
php_value post_max_size 55M
php_value upload_max_filesize 50M
php_value max_input_time 120
php_value default_socket_timeout 30
php_flag display_errors off
php_flag log_errors on
